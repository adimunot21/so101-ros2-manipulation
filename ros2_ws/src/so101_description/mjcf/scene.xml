<mujoco model="so101_manipulation_scene">
  <include file="so101_new_calib.xml" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="160" elevation="-20" />
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072" />
    <texture type="2d" name="table_tex" builtin="flat"
             rgb1="0.6 0.5 0.4" width="512" height="512" />
    <material name="table_mat" texture="table_tex" specular="0.3" shininess="0.5" />
  </asset>

  <worldbody>
    <light pos="1 1 3.5" dir="-0.27 -0.27 -0.92" directional="true" diffuse="0.5 0.5 0.5"/>
    <light pos="0 0 3.5" dir="0 0 -1" directional="true" diffuse="0.5 0.5 0.5"/>

    <!-- Floor below table -->
    <geom name="floor" type="plane" size="0 0 0.05" pos="0 0 -0.6"
          rgba="0.2 0.3 0.4 1" contype="1" conaffinity="1"/>

    <!-- Table: surface at z=0 -->
    <body name="table" pos="0.1 0 -0.3">
      <geom name="table_top" type="box" size="0.3 0.2 0.3"
            material="table_mat" mass="10" contype="1" conaffinity="1"/>
    </body>

    <!-- Cube on table -->
    <body name="cube" pos="0.28 0.0 0.02">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02"
            rgba="0.8 0.2 0.2 1" mass="0.02"
            contype="1" conaffinity="1" condim="4" friction="1 0.05 0.001"
            solref="0.01 1" solimp="0.95 0.99 0.001"/>
    </body>

    <!-- Overhead camera -->
    <camera name="overhead_cam" pos="0.20 0.10 0.7" quat="1 0 0 0"
            fovy="75" resolution="640 480"/>
  </worldbody>
</mujoco>
